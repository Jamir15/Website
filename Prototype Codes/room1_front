// ================= FIREBASE AUTH =================
bool firebaseSignIn() {
  HTTPClient http;
  String url = "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  StaticJsonDocument<256> doc;
  doc["email"] = email;
  doc["password"] = passwordFirebase;
  doc["returnSecureToken"] = true;

  String payload;
  serializeJson(doc, payload);

  int code = http.POST(payload);

  if (code == 200) {
    StaticJsonDocument<2048> response;
    DeserializationError err = deserializeJson(response, http.getString());

    if (!err) {
      idToken = response["idToken"].as<String>();
      refreshToken = response["refreshToken"].as<String>();
      int expiresIn = response["expiresIn"].as<int>();
      tokenExpiryTime = millis() + (expiresIn - 60UL) * 1000UL;

      http.end();
      return true;
    }
  }

  http.end();
  return false;
}

bool refreshFirebaseToken() {
  HTTPClient http;
  String url = "https://securetoken.googleapis.com/v1/token?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  StaticJsonDocument<512> doc;
  doc["grant_type"] = "refresh_token";
  doc["refresh_token"] = refreshToken;

  String payload;
  serializeJson(doc, payload);

  int code = http.POST(payload);

  if (code == 200) {
    StaticJsonDocument<2048> response;
    DeserializationError err = deserializeJson(response, http.getString());

    if (!err) {
      idToken = response["id_token"].as<String>();
      refreshToken = response["refresh_token"].as<String>();
      int expiresIn = response["expires_in"].as<int>();
      tokenExpiryTime = millis() + (expiresIn - 60UL) * 1000UL;

      http.end();
      return true;
    }
  }

  http.end();
  return firebaseSignIn();
}

void ensureValidToken() {
  if (millis() >= tokenExpiryTime) {
    refreshFirebaseToken();
  }
}

// ================= TIME HELPERS =================
void beginNtpSync() {
  if (!ntpConfigured) {
    configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");
    ntpConfigured = true;
    lastNtpRetry = millis();
  }
}

void maintainTimeSync() {
  if (!ntpConfigured) {
    beginNtpSync();
  }

  struct tm tmInfo;
  if (getLocalTime(&tmInfo, 0)) {
    timeSynced = true;
    return;
  }

  if (millis() - lastNtpRetry >= NTP_RETRY_INTERVAL) {
    lastNtpRetry = millis();
    configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");
  }
}

bool getCurrentUtcTime(struct tm &tmInfo) {
  time_t now;
  time(&now);

  if (now < 1700000000) {
    return false;
  }

  struct tm* timePtr = gmtime(&now);
  if (!timePtr) {
    return false;
  }

  tmInfo = *timePtr;
  return true;
}

void addTimestampField(JsonObject fields) {
  struct tm tmInfo;
  if (getCurrentUtcTime(tmInfo)) {
    char isoTime[25];
    sprintf(isoTime, "%04d-%02d-%02dT%02d:%02d:%02dZ",
            tmInfo.tm_year + 1900,
            tmInfo.tm_mon + 1,
            tmInfo.tm_mday,
            tmInfo.tm_hour,
            tmInfo.tm_min,
            tmInfo.tm_sec);

    fields["timestamp"]["timestampValue"] = String(isoTime);
  }
}

// ================= FIRESTORE SEND =================
void sendAHT() {
  ensureValidToken();
  maintainTimeSync();

  HTTPClient http;
  String url = "https://firestore.googleapis.com/v1/projects/" + String(projectID) +
               "/databases/(default)/documents/sensorData/room1_front?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Authorization", "Bearer " + idToken);

  StaticJsonDocument<384> doc;
  JsonObject fields = doc.createNestedObject("fields");

  fields["Temperature"]["doubleValue"] = latestTemp;
  fields["Humidity"]["doubleValue"] = latestHum;
  fields["deviceUptimeMs"]["integerValue"] = String((unsigned long long)millis());

  addTimestampField(fields);

  String json;
  serializeJson(doc, json);

  http.PATCH(json);
  http.end();
}

void sendAHTHistory() {
  ensureValidToken();
  maintainTimeSync();

  HTTPClient http;
  String url = "https://firestore.googleapis.com/v1/projects/" + String(projectID) +
               "/databases/(default)/documents/room1_front_logs?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Authorization", "Bearer " + idToken);

  StaticJsonDocument<384> doc;
  JsonObject fields = doc.createNestedObject("fields");

  fields["Temperature"]["doubleValue"] = latestTemp;
  fields["Humidity"]["doubleValue"] = latestHum;

  addTimestampField(fields);

  String json;
  serializeJson(doc, json);

  http.POST(json);
  http.end();
}

void sendThermal() {
  ensureValidToken();
  maintainTimeSync();

  HTTPClient http;
  String url = "https://firestore.googleapis.com/v1/projects/" + String(projectID) +
               "/databases/(default)/documents/thermalRooms/room1?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Authorization", "Bearer " + idToken);

  StaticJsonDocument<40000> doc;
  JsonObject fields = doc.createNestedObject("fields");

  JsonObject frame = fields.createNestedObject("frame");
  JsonObject arrObj = frame.createNestedObject("arrayValue");
  JsonArray arr = arrObj.createNestedArray("values");

  for (int i = 0; i < 768; i++) {
    JsonObject v = arr.createNestedObject();
    v["integerValue"] = compressedFrame[i] / 10;
  }

  fields["width"]["integerValue"]  = 32;
  fields["height"]["integerValue"] = 24;
  fields["deviceUptimeMs"]["integerValue"] = String((unsigned long long)millis());

  addTimestampField(fields);

  String json;
  serializeJson(doc, json);

  http.PATCH(json);
  http.end();
}

// ================= TFT UPDATE =================
void updateTFT() {
  display.setFont(&fonts::FreeSansBold12pt7b);
  display.setTextColor(TFT_BLACK);

  display.fillRect(TEMP_BG_X, TEMP_BG_Y, TEMP_BG_W, TEMP_BG_H, TFT_WHITE);
  display.setTextSize(TEMP_SX, TEMP_SY);
  display.setCursor(TEMP_X, TEMP_Y);
  display.printf("%.1f", latestTemp);
  display.drawCircle(DEG_X, DEG_Y, DEG_R, TFT_BLACK);
  display.setCursor(C_LABEL_X, TEMP_Y);
  display.print("C");

  display.fillRect(HUM_BG_X, HUM_BG_Y, HUM_BG_W, HUM_BG_H, TFT_WHITE);
  display.setTextSize(HUM_SX, HUM_SY);
  display.setCursor(HUM_X, HUM_Y);
  display.printf("%.1f %%", latestHum);
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  display.init();
  display.setRotation(1);
  display.setSwapBytes(true);
  display.pushImage(0, 0, 320, 240, TFT2);

  Wire.begin(21, 22);
  Wire.setClock(400000);

  if (!aht.begin()) {
    while (1);
  }

  if (!mlx.begin(MLX90640_I2CADDR_DEFAULT, &Wire)) {
    while (1);
  }

  mlx.setMode(MLX90640_CHESS);
  mlx.setResolution(MLX90640_ADC_18BIT);
  mlx.setRefreshRate(MLX90640_4_HZ);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  beginNtpSync();
  firebaseSignIn();
}

// ================= LOOP =================
void loop() {
  unsigned long now = millis();

  maintainTimeSync();

  if (now - lastMLXRead >= MLX_READ_INTERVAL) {
    lastMLXRead = now;

    if (mlx.getFrame(thermalFrame) == 0) {
      for (int i = 0; i < 768; i++) {
        compressedFrame[i] = thermalFrame[i] * 100;
      }
    }
  }

  if (now - lastSync >= SYNC_INTERVAL) {
    lastSync = now;

    sensors_event_t h, t;
    aht.getEvent(&h, &t);

    latestTemp = t.temperature;
    latestHum  = h.relative_humidity;

    updateTFT();
    sendAHT();
    sendAHTHistory();
    sendThermal();
  }
}
