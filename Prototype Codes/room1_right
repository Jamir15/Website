// ================= AUTH =================
bool firebaseSignIn() {
  HTTPClient http;

  String url =
    "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=" +
    String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  StaticJsonDocument<256> doc;
  doc["email"] = email;
  doc["password"] = passwordFirebase;
  doc["returnSecureToken"] = true;

  String payload;
  serializeJson(doc, payload);

  int code = http.POST(payload);

  if (code == 200) {
    StaticJsonDocument<2048> res;
    DeserializationError err = deserializeJson(res, http.getString());

    if (!err) {
      idToken = res["idToken"].as<String>();
      refreshToken = res["refreshToken"].as<String>();

      int expiresIn = res["expiresIn"].as<int>();
      tokenExpiryTime = millis() + (expiresIn - 60) * 1000UL;

      http.end();
      return true;
    }
  }

  http.end();
  return false;
}

bool refreshFirebaseToken() {
  HTTPClient http;

  String url =
    "https://securetoken.googleapis.com/v1/token?key=" + String(apiKey);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  StaticJsonDocument<512> doc;
  doc["grant_type"] = "refresh_token";
  doc["refresh_token"] = refreshToken;

  String payload;
  serializeJson(doc, payload);

  int code = http.POST(payload);

  if (code == 200) {
    StaticJsonDocument<2048> res;
    DeserializationError err = deserializeJson(res, http.getString());

    if (!err) {
      idToken = res["id_token"].as<String>();
      refreshToken = res["refresh_token"].as<String>();

      int expiresIn = res["expires_in"].as<int>();
      tokenExpiryTime = millis() + (expiresIn - 60) * 1000UL;

      http.end();
      return true;
    }
  }

  http.end();
  return firebaseSignIn();
}

void ensureValidToken() {
  if (millis() >= tokenExpiryTime) {
    refreshFirebaseToken();
  }
}

// ================= TIME =================
void beginNtpSync() {
  if (!ntpConfigured) {
    configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");
    ntpConfigured = true;
    lastNtpRetry = millis();
  }
}

void maintainTimeSync() {
  if (!ntpConfigured) {
    beginNtpSync();
  }

  struct tm tmInfo;
  if (getLocalTime(&tmInfo, 0)) {
    timeSynced = true;
    return;
  }

  if (millis() - lastNtpRetry >= NTP_RETRY_INTERVAL) {
    lastNtpRetry = millis();
    configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");
  }
}

bool getCurrentUtcTime(struct tm &tmInfo) {
  time_t now;
  time(&now);

  if (now < 1700000000) {
    return false;
  }

  struct tm* timePtr = gmtime(&now);
  if (!timePtr) {
    return false;
  }

  tmInfo = *timePtr;
  return true;
}

void addTimestamp(JsonObject fields) {
  struct tm tmInfo;
  if (getCurrentUtcTime(tmInfo)) {
    char iso[25];
    sprintf(
      iso,
      "%04d-%02d-%02dT%02d:%02d:%02dZ",
      tmInfo.tm_year + 1900,
      tmInfo.tm_mon + 1,
      tmInfo.tm_mday,
      tmInfo.tm_hour,
      tmInfo.tm_min,
      tmInfo.tm_sec
    );

    fields["timestamp"]["timestampValue"] = iso;
  }
}

// ================= FIRESTORE =================
bool updateFirestore(float temp, float hum) {
  if (idToken == "") return false;

  ensureValidToken();
  maintainTimeSync();

  HTTPClient http;

  String url =
    "https://firestore.googleapis.com/v1/projects/" + String(projectID) +
    "/databases/(default)/documents/" + String(documentPath);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Authorization", "Bearer " + idToken);

  StaticJsonDocument<512> doc;
  JsonObject f = doc.createNestedObject("fields");

  f["Temperature"]["doubleValue"] = temp;
  f["Humidity"]["doubleValue"] = hum;
  f["deviceUptimeMs"]["integerValue"] = String((unsigned long long)millis());
  addTimestamp(f);

  String json;
  serializeJson(doc, json);

  int code = http.PATCH(json);

  Serial.print("LIVE HTTP: ");
  Serial.println(code);

  http.end();
  return code >= 200 && code < 300;
}

bool writeHistoricalLog(float temp, float hum) {
  if (idToken == "") return false;

  ensureValidToken();
  maintainTimeSync();

  HTTPClient http;

  String url =
    "https://firestore.googleapis.com/v1/projects/" + String(projectID) +
    "/databases/(default)/documents/" + String(historicalLogPath);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Authorization", "Bearer " + idToken);

  StaticJsonDocument<512> doc;
  JsonObject f = doc.createNestedObject("fields");

  f["Temperature"]["doubleValue"] = temp;
  f["Humidity"]["doubleValue"] = hum;
  f["nodeName"]["stringValue"] = "room1_right";
  addTimestamp(f);

  String json;
  serializeJson(doc, json);

  int code = http.POST(json);

  Serial.print("LOG HTTP: ");
  Serial.println(code);

  http.end();
  return code >= 200 && code < 300;
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  delay(100);

  // TFT INIT
  display.init();
  display.setRotation(1);
  display.setSwapBytes(true);
  display.invertDisplay(false);
  display.pushImage(0, 0, 320, 240, TFT2);

  // SENSOR INIT
  if (!aht.begin()) {
    Serial.println("AHT20 not found");
    while (1) delay(10);
  }

  // WIFI INIT
  WiFi.begin(ssid, wifiPassword);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected!");
  Serial.println(WiFi.localIP());

  // NTP + FIREBASE
  beginNtpSync();

  Serial.println("Signing in to Firebase...");
  if (firebaseSignIn()) {
    Serial.println("Firebase Auth Success!");
  } else {
    Serial.println("Firebase Auth Failed!");
  }
}

// ================= LOOP =================
void loop() {
  maintainTimeSync();

  unsigned long now = millis();

  if (now - lastSync >= SYNC_INTERVAL) {
    lastSync = now;

    sensors_event_t humidity_event, temp_event;
    aht.getEvent(&humidity_event, &temp_event);

    float temperature = temp_event.temperature;
    float relHumidity = humidity_event.relative_humidity;

    Serial.printf("Temperature: %.2f C\n", temperature);
    Serial.printf("Humidity: %.2f %%\n", relHumidity);

    bool fsSuccess = updateFirestore(temperature, relHumidity);
    bool logSuccess = writeHistoricalLog(temperature, relHumidity);

    Serial.print("LIVE: ");
    Serial.println(fsSuccess);

    Serial.print("LOG: ");
    Serial.println(logSuccess);

    // TFT DISPLAY
    display.setFont(&fonts::FreeSansBold12pt7b);
    display.setTextColor(TFT_BLACK);

    // Temperature
    display.fillRect(TEMP_BG_X, TEMP_BG_Y, TEMP_BG_W, TEMP_BG_H, TFT_WHITE);
    display.setTextSize(TEMP_SX, TEMP_SY);
    display.setCursor(TEMP_X, TEMP_Y);
    display.printf("%.1f", temperature);
    display.drawCircle(DEG_X, DEG_Y, DEG_R, TFT_BLACK);
    display.setCursor(C_LABEL_X, TEMP_Y);
    display.print("C");

    // Humidity
    display.fillRect(HUM_BG_X, HUM_BG_Y, HUM_BG_W, HUM_BG_H, TFT_WHITE);
    display.setTextSize(HUM_SX, HUM_SY);
    display.setCursor(HUM_X, HUM_Y);
    display.printf("%.1f %%", relHumidity);

    // Status
    display.setTextSize(1);
    display.setCursor(10, 300);
    display.fillRect(10, 300, 260, 20, TFT_WHITE);

    if (fsSuccess && logSuccess) {
      display.setTextColor(TFT_GREEN);
      display.print("Live + history upload success");
    } else if (fsSuccess && !logSuccess) {
      display.setTextColor(TFT_ORANGE);
      display.print("Live OK, history FAILED");
    } else {
      display.setTextColor(TFT_RED);
      display.print("Firestore update FAILED");
    }
  }
}
